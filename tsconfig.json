{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "types": [
      "vinxi/types/client",
    ],
    "isolatedModules": true,
    "paths": {
      "~/*": [
        "./src/*"
      ],
    },
  },
}
